PORT=5000
NODE_ENV=development
MONGODB_URI=your_mongodb_atlas_connection_string_here
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000

# Required only when running npm run seed:owner
SEED_OWNER_EMAIL=RezaulOwner@gmail.com
SEED_OWNER_PASSWORD=your_local_owner_password
UPLOAD_DIR=uploads

# Storage driver: local or cloudinary
STORAGE_DRIVER=cloudinary
STORAGE_FOLDER=easy-ecommerce/products
STORAGE_MAX_FILE_SIZE_MB=5
STORAGE_MAX_FILES=10

# Required when STORAGE_DRIVER=cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
